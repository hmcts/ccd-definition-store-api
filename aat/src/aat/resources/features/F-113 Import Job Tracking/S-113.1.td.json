{
  "_guid_": "S-113.1",
  "_extends_": "F-113_Import_Base_data",
  "title": "must successfully import a definition file with a supplied job id and retrieve its status",

  "specs": [
    "contains a supplied X-Import-Job-Id request header"
  ],

  "request": {
    "headers": {
      "Authorization": "[[DEFAULT_AUTO_VALUE]]",
      "ServiceAuthorization": "[[DEFAULT_AUTO_VALUE]]",
      "Content-Type": "multipart/form-data",
      "X-Import-Job-Id": "${[scenarioContext][customValues][unique_import_job_id]}"
    },
    "body": {
      "arrayInMap": [
        {
          "key": "file",
          "localFilePath": "build/tmp/definition_files_copy/BEFTA_MASTER.xlsx"
        }
      ]
    }
  },

  "expectedResponse": {
    "_extends_": "Common_201_Response",
    "headers": {
      "Content-Encoding": "[[ANYTHING_PRESENT]]",
      "Content-Type": "application/json",
      "Content-Length": "[[ANYTHING_PRESENT]]",
      "X-Import-Job-Id": "[[ANY_STRING_NOT_NULLABLE]]"
    },
    "body": {
      "__plainTextValue__": "Case Definition data successfully imported"
    }
  }
}
